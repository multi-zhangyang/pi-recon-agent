{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/tool-call-trace-ledger.schema.json",
  "title": "ToolCallTraceLedgerV1",
  "description": "append_only_tool_trace, secret_redaction_required, replayable_tool_result_hashes, result_requires_prior_call, tool_output_hash_required",
  "type": "object",
  "required": ["kind", "schemaVersion", "generatedAt", "ledgerPath", "eventCount", "callCount", "resultCount", "errorCount", "hashChainOk", "secretRedactionOk", "replayCoverage", "events"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "ToolCallTraceLedgerV1" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string" },
    "ledgerPath": { "type": "string" },
    "eventCount": { "type": "integer", "minimum": 0 },
    "callCount": { "type": "integer", "minimum": 0 },
    "resultCount": { "type": "integer", "minimum": 0 },
    "errorCount": { "type": "integer", "minimum": 0 },
    "hashChainOk": { "type": "boolean" },
    "secretRedactionOk": { "type": "boolean" },
    "replayCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/ToolCallTraceEventV1" }
    }
  },
  "$defs": {
    "ToolCallTraceEventV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "eventId", "ts", "toolCallId", "toolName", "phase", "status", "inputSha256", "inputPreviewRedacted", "replay", "assertions", "prevHash", "eventHash"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "ToolCallTraceEventV1" },
        "schemaVersion": { "const": 1 },
        "eventId": { "type": "string" },
        "ts": { "type": "string" },
        "missionId": { "type": "string" },
        "toolCallId": { "type": "string" },
        "toolName": { "type": "string" },
        "phase": { "enum": ["call", "result"] },
        "status": { "enum": ["running", "pass", "error", "blocked", "cancelled"] },
        "inputSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "inputPreviewRedacted": { "type": "string" },
        "commandPreviewRedacted": { "type": "string" },
        "outputSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "outputPreviewRedacted": { "type": "string" },
        "detailsSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "replay": {
          "type": "object",
          "required": ["available", "redacted", "deterministic"],
          "additionalProperties": false,
          "properties": {
            "available": { "type": "boolean" },
            "command": { "type": "string" },
            "redacted": { "const": true },
            "deterministic": { "type": "boolean" }
          }
        },
        "assertions": {
          "type": "object",
          "required": ["toolCallIdPresent", "inputHashed", "outputHashed", "secretRedacted", "replayHintPresent", "appendOnlyHashChain"],
          "additionalProperties": false,
          "properties": {
            "toolCallIdPresent": { "type": "boolean" },
            "inputHashed": { "type": "boolean" },
            "outputHashed": { "type": "boolean" },
            "secretRedacted": { "type": "boolean" },
            "replayHintPresent": { "type": "boolean" },
            "appendOnlyHashChain": { "type": "boolean" }
          }
        },
        "prevHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "eventHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  },
  "x-repiStrictFixture": "fixtures/reverse-agent/tool-call-trace-ledger.fixture.json",
  "x-repiInvariants": [
    "append_only_tool_trace",
    "secret_redaction_required",
    "replayable_tool_result_hashes",
    "result_requires_prior_call",
    "tool_output_hash_required"
  ]
}
