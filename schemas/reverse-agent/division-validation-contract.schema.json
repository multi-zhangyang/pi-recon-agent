{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pi-recon.local/schemas/reverse-agent/division-validation-contract.schema.json",
  "title": "Pi-RECON Division Validation Contract",
  "$defs": {
    "DivisionValidationContractV1": {
      "title": "Pi-RECON Division Validation Contract V1",
      "type": "object",
      "required": [
        "contractVersion",
        "runId",
        "evidenceOrder",
        "roles",
        "ledgerPolicy",
        "conflictPolicy",
        "claimGatePolicy"
      ],
      "properties": {
        "contractVersion": { "const": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "evidenceOrder": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "same_window_live" }
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "mustEmit", "allowedClaimKinds", "forbiddenClaimKinds", "handoffTargets", "evidenceContract"],
            "properties": {
              "id": { "type": "string" },
              "mustEmit": { "type": "array", "items": { "type": "string" } },
              "allowedClaimKinds": { "type": "array", "items": { "type": "string" } },
              "forbiddenClaimKinds": { "type": "array", "items": { "type": "string" } },
              "handoffTargets": { "type": "array", "items": { "type": "string" } },
              "evidenceContract": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        },
        "ledgerPolicy": {
          "type": "object",
          "required": ["appendOnly", "prevHash", "eventHash", "requiredEventTypes"],
          "properties": {
            "appendOnly": { "const": true },
            "prevHash": { "type": "string" },
            "eventHash": { "type": "string" },
            "requiredEventTypes": {
              "type": "array",
              "items": {
                "enum": ["artifact_handoff", "claim", "validation", "challenge", "resolution"]
              }
            }
          },
          "additionalProperties": true
        },
        "conflictPolicy": {
          "type": "object",
          "required": ["tableRequired", "evidenceOrder", "unresolvedBlocksFinal"],
          "properties": {
            "tableRequired": { "const": true },
            "evidenceOrder": { "type": "array", "items": { "type": "string" } },
            "unresolvedBlocksFinal": { "const": true }
          },
          "additionalProperties": true
        },
        "claimGatePolicy": {
          "type": "object",
          "required": [
            "provenRequiresArtifactSha256",
            "provenRequiresJsonQuery",
            "finalPassRequiresVerifier",
            "unresolvedChallengeBlocks"
          ],
          "properties": {
            "provenRequiresArtifactSha256": { "const": true },
            "provenRequiresJsonQuery": { "const": true },
            "finalPassRequiresVerifier": { "const": true },
            "unresolvedChallengeBlocks": { "const": true }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true,
      "x-piReconInvariants": [
        "proven_or_final_pass_claim_requires_artifact_sha256_and_json_query",
        "verifier_pass_required_before_final_pass",
        "unresolved_adversary_challenge_blocks_claim_promotion",
        "synthesizer_must_emit_conflict_table",
        "orchestration_score_must_not_imply_platform_claim_success"
      ]
    }
  },
  "$ref": "#/$defs/DivisionValidationContractV1"
}
