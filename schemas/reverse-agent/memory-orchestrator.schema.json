{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/memory-orchestrator.schema.json",
  "title": "REPI Memory Orchestrator V6",
  "description": "MemoryOrchestratorV6 makes memory a mandatory harness control loop: pre_task_retrieve_before_operator, scope_filter_before_memory_injection, post_tool_writeback_contract, pre_compact_memory_snapshot, post_compact_resume_memory_injection, final_supervise_before_claim.",
  "$defs": {
    "MemoryScopeV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "sessionId",
        "cwd",
        "workspaceRoot",
        "branchId"
      ],
      "properties": {
        "kind": {
          "const": "repi-memory-scope"
        },
        "schemaVersion": {
          "const": 1
        },
        "missionId": {
          "type": "string"
        },
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "workspaceRoot": {
          "type": "string",
          "minLength": 1
        },
        "branchId": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "MemoryOrchestratorStepV6": {
      "type": "object",
      "required": [
        "id",
        "phase",
        "status",
        "title",
        "command",
        "reason",
        "blocking"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "$ref": "#/$defs/MemoryOrchestratorPhaseV6"
        },
        "status": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "pending"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "evidencePath": {
          "type": "string"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "MemoryOrchestratorPhaseV6": {
      "enum": [
        "pre-task",
        "pre-operator",
        "post-tool",
        "post-failure",
        "post-success",
        "pre-compact",
        "post-compact",
        "final",
        "full"
      ]
    },
    "MemoryOrchestratorReportV6": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "MemoryOrchestratorV6",
        "mandatory_memory_control_loop",
        "phase",
        "reportPath",
        "currentScope",
        "query",
        "storeGrade",
        "hashChainOk",
        "retrievalReportPath",
        "retrievalHitIds",
        "vectorSearchReportPath",
        "vectorHitIds",
        "scopeIsolationReportPath",
        "scopeBlockedEventIds",
        "scopeWarnEventIds",
        "artifactScopeFilterReportPath",
        "artifactScopeBlockedArtifacts",
        "injectionPacketPath",
        "injectionEventIds",
        "injectionCommands",
        "feedbackClosureReportPath",
        "feedbackPendingEventIds",
        "supervisorReportPath",
        "promotionEventIds",
        "demotionEventIds",
        "compactResumeLedgerPath",
        "compactResumeStatus",
        "compactResumeLedgerV2ReportPath",
        "compactResumeLedgerV2Status",
        "compactResumeLedgerV2State",
        "compactResumeLedgerV2InvalidTransitions",
        "memoryDepositionReportPath",
        "memoryDepositionEventBusPath",
        "memoryDepositionStatus",
        "memoryDepositionRuntimeEventCount",
        "memoryDepositionPendingWritebacks",
        "memoryExperienceReportPath",
        "memoryExperienceStatus",
        "memoryExperienceEpisodeCount",
        "memoryExperienceClaimCount",
        "memoryExperienceLessonCount",
        "memoryExperiencePromotedClaims",
        "memoryExperienceConflictedClaims",
        "memorySkillCapsuleReportPath",
        "memorySkillCapsuleStatus",
        "memorySkillCapsuleCount",
        "memorySkillCapsulePromoted",
        "memorySkillCapsuleCandidates",
        "memoryDistillPromotionReportPath",
        "memoryDistillPromotionStatus",
        "memoryDistillPromotionCandidateCount",
        "memoryDistillPromotionPromoted",
        "memoryDistillPromotionRetained",
        "memoryQualityReportPath",
        "memoryQualityStatus",
        "memoryQualityRowCount",
        "memoryQualityPromoted",
        "memoryQualityDemoted",
        "memoryQualityRequiredFeedback",
        "memoryReplayReportPath",
        "memoryReplayStatus",
        "memoryReplayScenarioCount",
        "memoryReplayImproved",
        "memoryReplayRegressed",
        "memoryStrategyReportPath",
        "memoryStrategyStatus",
        "memoryStrategyCapsuleCount",
        "memoryStrategyPromoted",
        "memoryStrategyDemoted",
        "memoryActiveKernelReportPath",
        "memoryActiveKernelStatus",
        "memoryActiveKernelDecisionCount",
        "memoryActiveKernelInject",
        "memoryActiveKernelAvoid",
        "memoryMaturationReportPath",
        "memoryMaturationStatus",
        "memoryMaturationRowCount",
        "memoryMaturationPromoted",
        "memoryMaturationPending",
        "steps",
        "nextCommands",
        "requiredGates",
        "policy"
      ],
      "properties": {
        "kind": {
          "const": "repi-memory-orchestrator-report"
        },
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "MemoryOrchestratorV6": {
          "const": true
        },
        "mandatory_memory_control_loop": {
          "const": true
        },
        "phase": {
          "$ref": "#/$defs/MemoryOrchestratorPhaseV6"
        },
        "reportPath": {
          "type": "string",
          "minLength": 1
        },
        "currentScope": {
          "$ref": "#/$defs/MemoryScopeV1"
        },
        "query": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "storeGrade": {
          "enum": [
            "pass",
            "repairable",
            "blocked"
          ]
        },
        "hashChainOk": {
          "type": "boolean"
        },
        "retrievalReportPath": {
          "type": "string"
        },
        "retrievalHitIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "vectorSearchReportPath": {
          "type": "string"
        },
        "vectorHitIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scopeIsolationReportPath": {
          "type": "string"
        },
        "scopeBlockedEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scopeWarnEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifactScopeFilterReportPath": {
          "type": "string"
        },
        "artifactScopeBlockedArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "injectionPacketPath": {
          "type": "string"
        },
        "injectionEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "injectionCommands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "feedbackClosureReportPath": {
          "type": "string"
        },
        "feedbackPendingEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supervisorReportPath": {
          "type": "string"
        },
        "promotionEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "demotionEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compactResumeLedgerPath": {
          "type": "string"
        },
        "compactResumeStatus": {
          "enum": [
            "pass",
            "missing",
            "corrupt"
          ]
        },
        "memoryDepositionReportPath": {
          "type": "string"
        },
        "memoryDepositionEventBusPath": {
          "type": "string"
        },
        "memoryDepositionStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryDepositionRuntimeEventCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryDepositionPendingWritebacks": {
          "type": "integer",
          "minimum": 0
        },
        "steps": {
          "type": "array",
          "minItems": 7,
          "items": {
            "$ref": "#/$defs/MemoryOrchestratorStepV6"
          }
        },
        "nextCommands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredGates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy": {
          "type": "object",
          "required": [
            "MemoryOrchestratorV6",
            "preTaskRetrieveBeforeOperator",
            "scopeFilterBeforeMemoryInjection",
            "postToolWritebackContract",
            "memoryDepositionEngine",
            "memoryExperienceEngine",
            "memorySkillCapsuleEngine",
            "memoryDistillPromotionEngine",
            "memoryQualityLedger",
            "memoryReplayEvaluator",
            "memoryStrategyCapsules",
            "memoryActiveKernel",
            "memoryMaturationRuntime",
            "failureSuccessFeedbackClosure",
            "preCompactMemorySnapshot",
            "postCompactResumeMemoryInjection",
            "finalSuperviseBeforeClaim"
          ],
          "properties": {
            "MemoryOrchestratorV6": {
              "const": true
            },
            "preTaskRetrieveBeforeOperator": {
              "const": true
            },
            "scopeFilterBeforeMemoryInjection": {
              "const": true
            },
            "postToolWritebackContract": {
              "const": true
            },
            "memoryDepositionEngine": {
              "const": true
            },
            "failureSuccessFeedbackClosure": {
              "const": true
            },
            "preCompactMemorySnapshot": {
              "const": true
            },
            "postCompactResumeMemoryInjection": {
              "const": true
            },
            "finalSuperviseBeforeClaim": {
              "const": true
            },
            "memoryExperienceEngine": {
              "const": true
            },
            "memorySkillCapsuleEngine": {
              "const": true
            },
            "memoryDistillPromotionEngine": {
              "const": true
            },
            "memoryQualityLedger": {
              "const": true
            },
            "memoryReplayEvaluator": {
              "const": true
            },
            "memoryStrategyCapsules": {
              "const": true
            },
            "memoryActiveKernel": {
              "const": true
            },
            "memoryMaturationRuntime": {
              "const": true
            }
          },
          "additionalProperties": false
        },
        "compactResumeLedgerV2ReportPath": {
          "type": "string"
        },
        "compactResumeLedgerV2Status": {
          "enum": [
            "pass",
            "blocked"
          ]
        },
        "compactResumeLedgerV2State": {
          "enum": [
            "queued",
            "running",
            "done",
            "blocked",
            "exhausted"
          ]
        },
        "compactResumeLedgerV2InvalidTransitions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "memoryExperienceReportPath": {
          "type": "string"
        },
        "memoryExperienceStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryExperienceEpisodeCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryExperienceClaimCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryExperienceLessonCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryExperiencePromotedClaims": {
          "type": "integer",
          "minimum": 0
        },
        "memoryExperienceConflictedClaims": {
          "type": "integer",
          "minimum": 0
        },
        "memorySkillCapsuleReportPath": {
          "type": "string"
        },
        "memorySkillCapsuleStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memorySkillCapsuleCount": {
          "type": "integer",
          "minimum": 0
        },
        "memorySkillCapsulePromoted": {
          "type": "integer",
          "minimum": 0
        },
        "memorySkillCapsuleCandidates": {
          "type": "integer",
          "minimum": 0
        },
        "memoryDistillPromotionReportPath": {
          "type": "string"
        },
        "memoryDistillPromotionStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryDistillPromotionCandidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryDistillPromotionPromoted": {
          "type": "integer",
          "minimum": 0
        },
        "memoryDistillPromotionRetained": {
          "type": "integer",
          "minimum": 0
        },
        "memoryQualityReportPath": {
          "type": "string"
        },
        "memoryQualityStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryQualityRowCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryQualityPromoted": {
          "type": "integer",
          "minimum": 0
        },
        "memoryQualityDemoted": {
          "type": "integer",
          "minimum": 0
        },
        "memoryQualityRequiredFeedback": {
          "type": "integer",
          "minimum": 0
        },
        "memoryReplayReportPath": {
          "type": "string"
        },
        "memoryReplayStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryReplayScenarioCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryReplayImproved": {
          "type": "integer",
          "minimum": 0
        },
        "memoryReplayRegressed": {
          "type": "integer",
          "minimum": 0
        },
        "memoryStrategyReportPath": {
          "type": "string"
        },
        "memoryStrategyStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryStrategyCapsuleCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryStrategyPromoted": {
          "type": "integer",
          "minimum": 0
        },
        "memoryStrategyDemoted": {
          "type": "integer",
          "minimum": 0
        },
        "memoryActiveKernelReportPath": {
          "type": "string"
        },
        "memoryActiveKernelStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryActiveKernelDecisionCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryActiveKernelInject": {
          "type": "integer",
          "minimum": 0
        },
        "memoryActiveKernelAvoid": {
          "type": "integer",
          "minimum": 0
        },
        "memoryMaturationReportPath": {
          "type": "string"
        },
        "memoryMaturationStatus": {
          "enum": [
            "pass",
            "warn",
            "blocked",
            "empty"
          ]
        },
        "memoryMaturationRowCount": {
          "type": "integer",
          "minimum": 0
        },
        "memoryMaturationPromoted": {
          "type": "integer",
          "minimum": 0
        },
        "memoryMaturationPending": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
