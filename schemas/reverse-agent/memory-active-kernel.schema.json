{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/memory-active-kernel.schema.json",
  "title": "MemoryActiveKernelV14",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "generatedAt",
    "MemoryActiveKernelV14",
    "unified_memory_decision_engine",
    "active_recall_scheduler",
    "cross_session_compact_ready",
    "feedback_driven_promotion",
    "scope_safe_strategy_injection",
    "reportPath",
    "injectionPackPath",
    "strategyBoardPath",
    "decisionCount",
    "injectDecisionIds",
    "reuseDecisionIds",
    "verifyDecisionIds",
    "avoidDecisionIds",
    "quarantineDecisionIds",
    "operatorInjectionCommands",
    "verifierCommands",
    "fallbackCommands",
    "avoidCommands",
    "status",
    "decisions",
    "activeInjectionPack",
    "requiredGates",
    "policy",
    "nextCommands"
  ],
  "properties": {
    "kind": { "const": "repi-memory-active-kernel-report" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string" },
    "MemoryActiveKernelV14": { "const": true },
    "unified_memory_decision_engine": { "const": true },
    "active_recall_scheduler": { "const": true },
    "cross_session_compact_ready": { "const": true },
    "feedback_driven_promotion": { "const": true },
    "scope_safe_strategy_injection": { "const": true },
    "reportPath": { "type": "string" },
    "injectionPackPath": { "type": "string" },
    "strategyBoardPath": { "type": "string" },
    "sourceSedimentationReportPath": { "type": "string" },
    "sourceQualityReportPath": { "type": "string" },
    "sourceReplayReportPath": { "type": "string" },
    "sourceStrategyReportPath": { "type": "string" },
    "sourceFeedbackReportPath": { "type": "string" },
    "sourceScopeReportPath": { "type": "string" },
    "decisionCount": { "type": "integer", "minimum": 0 },
    "injectDecisionIds": { "type": "array", "items": { "type": "string" } },
    "reuseDecisionIds": { "type": "array", "items": { "type": "string" } },
    "verifyDecisionIds": { "type": "array", "items": { "type": "string" } },
    "repairDecisionIds": { "type": "array", "items": { "type": "string" } },
    "avoidDecisionIds": { "type": "array", "items": { "type": "string" } },
    "quarantineDecisionIds": { "type": "array", "items": { "type": "string" } },
    "pendingFeedbackDecisionIds": { "type": "array", "items": { "type": "string" } },
    "expiredDecisionIds": { "type": "array", "items": { "type": "string" } },
    "operatorInjectionCommands": { "type": "array", "items": { "type": "string" } },
    "verifierCommands": { "type": "array", "items": { "type": "string" } },
    "fallbackCommands": { "type": "array", "items": { "type": "string" } },
    "avoidCommands": { "type": "array", "items": { "type": "string" } },
    "workerRoutingHints": { "type": "array", "items": { "type": "string" } },
    "compactResumeHints": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["pass", "warn", "blocked", "empty"] },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "activeInjectionPack": { "$ref": "#/$defs/injectionPack" },
    "requiredGates": { "type": "array", "items": { "type": "string" } },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["MemoryActiveKernelV14", "unifiedMemoryDecisionEngine", "activeRecallScheduler", "qualityReplayStrategyFusion", "scopeSafeStrategyInjection", "feedbackDrivenPromotion", "crossSessionCompactReady"],
      "properties": {
        "MemoryActiveKernelV14": { "const": true },
        "unifiedMemoryDecisionEngine": { "const": true },
        "activeRecallScheduler": { "const": true },
        "qualityReplayStrategyFusion": { "const": true },
        "scopeSafeStrategyInjection": { "const": true },
        "feedbackDrivenPromotion": { "const": true },
        "crossSessionCompactReady": { "const": true }
      }
    },
    "nextCommands": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "action": { "enum": ["inject", "reuse", "verify", "repair", "avoid", "quarantine", "wait-feedback", "expire"] },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schemaVersion", "id", "ts", "MemoryActiveKernelV14", "unified_memory_decision_engine", "active_recall_scheduler", "scope_safe_strategy_injection", "action", "route", "targetScope", "source", "sourceEventIds", "sourceStrategyCapsuleIds", "sourceQualityRowIds", "sourceReplayRowIds", "activeScore", "causalScore", "qualityScore", "confidence", "commands", "verifierCommands", "fallbackCommands", "avoidCommands", "evidenceRefs", "triggerConditions", "applicabilityBoundary", "rationale", "preflightChecks", "feedbackWritebackCommands", "compactResumeHints", "blockers", "entryHash"],
      "properties": {
        "kind": { "const": "repi-memory-active-kernel-decision" },
        "schemaVersion": { "const": 1 },
        "id": { "type": "string" },
        "ts": { "type": "string" },
        "MemoryActiveKernelV14": { "const": true },
        "unified_memory_decision_engine": { "const": true },
        "active_recall_scheduler": { "const": true },
        "scope_safe_strategy_injection": { "const": true },
        "action": { "$ref": "#/$defs/action" },
        "route": { "type": "string" },
        "targetScope": { "type": "string" },
        "source": { "enum": ["strategy", "sedimentation", "quality", "feedback", "supervisor"] },
        "sourceEventIds": { "type": "array", "items": { "type": "string" } },
        "sourceStrategyCapsuleIds": { "type": "array", "items": { "type": "string" } },
        "sourceQualityRowIds": { "type": "array", "items": { "type": "string" } },
        "sourceReplayRowIds": { "type": "array", "items": { "type": "string" } },
        "activeScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "causalScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "qualityScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "commands": { "type": "array", "items": { "type": "string" } },
        "verifierCommands": { "type": "array", "items": { "type": "string" } },
        "fallbackCommands": { "type": "array", "items": { "type": "string" } },
        "avoidCommands": { "type": "array", "items": { "type": "string" } },
        "evidenceRefs": { "type": "array", "items": { "type": "string" } },
        "triggerConditions": { "type": "array", "items": { "type": "string" } },
        "applicabilityBoundary": { "type": "array", "items": { "type": "string" } },
        "rationale": { "type": "array", "items": { "type": "string" } },
        "preflightChecks": { "type": "array", "items": { "type": "string" } },
        "feedbackWritebackCommands": { "type": "array", "items": { "type": "string" } },
        "compactResumeHints": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "entryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "injectionPack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schemaVersion", "generatedAt", "MemoryActiveKernelV14", "active_recall_scheduler", "budget", "decisions", "commands", "verifierRules", "fallbackCommands", "avoidCommands", "scopeLocks", "feedbackWriteback", "compactResumeHints", "requiredGates"],
      "properties": {
        "kind": { "const": "repi-memory-active-injection-pack" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string" },
        "MemoryActiveKernelV14": { "const": true },
        "active_recall_scheduler": { "const": true },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxDecisions", "maxCommands", "maxTokens"],
          "properties": {
            "maxDecisions": { "type": "integer", "minimum": 1 },
            "maxCommands": { "type": "integer", "minimum": 1 },
            "maxTokens": { "type": "integer", "minimum": 1 }
          }
        },
        "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
        "commands": { "type": "array", "items": { "type": "string" } },
        "verifierRules": { "type": "array", "items": { "type": "string" } },
        "fallbackCommands": { "type": "array", "items": { "type": "string" } },
        "avoidCommands": { "type": "array", "items": { "type": "string" } },
        "scopeLocks": { "type": "array", "items": { "type": "string" } },
        "feedbackWriteback": { "type": "string" },
        "compactResumeHints": { "type": "array", "items": { "type": "string" } },
        "requiredGates": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
