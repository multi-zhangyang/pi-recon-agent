{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pi-recon.local/schemas/compact-resume-ledger-v2.schema.json",
  "title": "REPI CompactResumeLedgerV2",
  "$defs": {
    "CompactResumeStateV2": {
      "type": "string",
      "enum": ["queued", "running", "done", "blocked", "exhausted"]
    },
    "CompactResumeLedgerTransitionV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schemaVersion", "from", "to", "at", "reason", "idempotencyKey", "attempt", "maxAttempts", "entryHash", "prevHash"],
      "properties": {
        "kind": { "const": "repi-compact-resume-ledger-transition" },
        "schemaVersion": { "const": 1 },
        "from": { "$ref": "#/$defs/CompactResumeStateV2" },
        "to": { "$ref": "#/$defs/CompactResumeStateV2" },
        "at": { "type": "string", "format": "date-time" },
        "command": { "type": "string" },
        "reason": { "type": "string", "minLength": 1 },
        "idempotencyKey": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "contextPath": { "type": "string" },
        "contextSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "attempt": { "type": "integer", "minimum": 1 },
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "entryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "prevHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "CompactResumeLedgerV2Report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schemaVersion", "generatedAt", "CompactResumeLedgerV2", "append_only_transition_ledger", "idempotent_multi_compact_replay", "auto_resume_budget_enforced", "reportPath", "transitionPath", "currentState", "transitions", "invalidTransitions", "exhausted", "requiredGates"],
      "properties": {
        "kind": { "const": "repi-compact-resume-ledger-v2-report" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "CompactResumeLedgerV2": { "const": true },
        "append_only_transition_ledger": { "const": true },
        "idempotent_multi_compact_replay": { "const": true },
        "auto_resume_budget_enforced": { "const": true },
        "reportPath": { "type": "string" },
        "transitionPath": { "type": "string" },
        "currentState": { "$ref": "#/$defs/CompactResumeStateV2" },
        "transitions": { "type": "array", "items": { "$ref": "#/$defs/CompactResumeLedgerTransitionV2" } },
        "invalidTransitions": { "type": "array", "items": { "type": "string" } },
        "exhausted": { "type": "boolean" },
        "requiredGates": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
