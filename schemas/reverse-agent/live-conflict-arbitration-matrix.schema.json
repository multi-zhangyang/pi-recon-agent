        },
        "claimIds": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "winnerClaimId": {
          "type": "string",
          "minLength": 1
        },
        "parsedToStructuredRows": {
