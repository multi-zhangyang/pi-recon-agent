      "type": "object",
      "required": [
        "kind",
        "tableId",
        "windowId",
        "topic",
        "sameWindow",
        "conflictIds",
        "workerIds",
        "providerWorkerIds",
        "sourceKinds",
        "claimIds",
        "winnerClaimId",
        "winningEvidenceRefs",
        "loserClaimIds",
