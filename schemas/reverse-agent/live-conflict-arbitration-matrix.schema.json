          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceKinds": {
          "type": "array",
          "minItems": 2,
          "contains": {
            "const": "provider-worker"
          },
          "items": {
            "enum": [
              "agent-dogfood",
              "re_swarm",
              "compound-frontier",
              "provider-worker"
            ]
          }
        },
        "claimIds": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "winnerClaimId": {
          "type": "string",
          "minLength": 1
        },
        "winningEvidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "loserClaimIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "loserDowngradeBlocked": {
          "const": true
        },
        "jsonQueryVerifierPass": {
          "const": true
        },
        "providerRuntimeManifestRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requestLogRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
