    "LongRunSynthesizerNarrativeBlockedRowV1": {
      "type": "object",
      "required": [
        "sourceKind",
        "topic",
        "claimIds",
        "narrativeOnly",
        "blockedPromotion"
      ],
      "additionalProperties": false,
      "properties": {
        "sourceKind": {
          "enum": [
            "agent-dogfood",
            "re_swarm",
            "compound-frontier",
