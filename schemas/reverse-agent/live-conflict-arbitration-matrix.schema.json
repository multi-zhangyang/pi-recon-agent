    "LongRunSynthesizerTopicParseMatrixV1": {
      "type": "object",
      "required": [
        "kind",
        "parseId",
        "longRunWindowIds",
        "topicRows",
        "narrativeOnlyBlockedRows"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "LongRunSynthesizerTopicParseMatrixV1"
        },
        "parseId": {
          "type": "string",
          "minLength": 1
