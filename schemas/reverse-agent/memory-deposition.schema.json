{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/memory-deposition.schema.json",
  "title": "REPI Memory Deposition Engine V7",
  "description": "MemoryDepositionEngineV7 turns runtime steps into an append-only deposition event bus with post-tool writeback autocapture, memory-event hash binding, and context-pack visibility.",
  "$defs": {
    "ArtifactHash": {
      "type": "object",
      "required": ["path", "sha256", "tier"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": ["string", "null"] },
        "tier": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "MemoryDepositionRuntimeEventV7": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "id",
        "seq",
        "ts",
        "MemoryDepositionEngineV7",
        "stage",
        "source",
        "status",
        "task",
        "route",
        "outcome",
        "confidence",
        "artifactHashes",
        "claimIds",
        "lessons",
        "failurePatterns",
        "reuseRules",
        "commands",
        "reason",
        "prevHash",
        "entryHash"
      ],
      "properties": {
        "kind": { "const": "repi-memory-deposition-runtime-event" },
        "schemaVersion": { "const": 1 },
        "id": { "type": "string", "pattern": "^memdep:" },
        "seq": { "type": "integer", "minimum": 1 },
        "ts": { "type": "string", "format": "date-time" },
        "MemoryDepositionEngineV7": { "const": true },
        "stage": { "enum": ["tool", "shell", "agent", "swarm-worker", "compact-resume", "claim", "manual", "memory-event"] },
        "source": { "type": "string", "minLength": 1 },
        "status": { "enum": ["queued", "written", "skipped", "blocked"] },
        "task": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "minLength": 1 },
        "target": { "type": "string" },
        "command": { "type": "string" },
        "stdoutSha256": { "type": "string" },
        "stderrSha256": { "type": "string" },
        "exitCode": { "type": "integer" },
        "outcome": { "enum": ["success", "failure", "blocked", "partial", "repair"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "artifactHashes": { "type": "array", "items": { "$ref": "#/$defs/ArtifactHash" } },
        "claimIds": { "type": "array", "items": { "type": "string" } },
        "compactResumeId": { "type": "string" },
        "lessons": { "type": "array", "items": { "type": "string" } },
        "failurePatterns": { "type": "array", "items": { "type": "string" } },
        "reuseRules": { "type": "array", "items": { "type": "string" } },
        "commands": { "type": "array", "items": { "type": "string" } },
        "memoryEventId": { "type": "string" },
        "caseSignature": { "type": "string" },
        "reason": { "type": "string", "minLength": 1 },
        "prevHash": { "type": "string", "minLength": 64 },
        "entryHash": { "type": "string", "minLength": 64 }
      },
      "additionalProperties": false
    },
    "MemoryDepositionReportV7": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "MemoryDepositionEngineV7",
        "runtime_step_event_bus",
        "post_tool_writeback_autocapture",
        "depositionReportPath",
        "depositionEventBusPath",
        "memoryEventsPath",
        "storeReportPath",
        "runtimeEventCount",
        "memoryWritebackCount",
        "pendingWritebackCount",
        "blockedWritebackCount",
        "skippedWritebackCount",
        "autoWritebackCoverage",
        "status",
        "latestRuntimeEventHash",
        "storeGrade",
        "recentEvents",
        "pendingEventIds",
        "blockedEventIds",
        "requiredGates",
        "policy",
        "nextCommands"
      ],
      "properties": {
        "kind": { "const": "repi-memory-deposition-report" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "MemoryDepositionEngineV7": { "const": true },
        "runtime_step_event_bus": { "const": true },
        "post_tool_writeback_autocapture": { "const": true },
        "depositionReportPath": { "type": "string", "minLength": 1 },
        "depositionEventBusPath": { "type": "string", "minLength": 1 },
        "memoryEventsPath": { "type": "string", "minLength": 1 },
        "storeReportPath": { "type": "string", "minLength": 1 },
        "runtimeEventCount": { "type": "integer", "minimum": 0 },
        "memoryWritebackCount": { "type": "integer", "minimum": 0 },
        "pendingWritebackCount": { "type": "integer", "minimum": 0 },
        "blockedWritebackCount": { "type": "integer", "minimum": 0 },
        "skippedWritebackCount": { "type": "integer", "minimum": 0 },
        "autoWritebackCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "enum": ["pass", "warn", "blocked", "empty"] },
        "latestRuntimeEventHash": { "type": "string", "minLength": 64 },
        "storeGrade": { "enum": ["pass", "repairable", "blocked"] },
        "recentEvents": { "type": "array", "items": { "$ref": "#/$defs/MemoryDepositionRuntimeEventV7" } },
        "pendingEventIds": { "type": "array", "items": { "type": "string" } },
        "blockedEventIds": { "type": "array", "items": { "type": "string" } },
        "requiredGates": { "type": "array", "items": { "type": "string" } },
        "policy": {
          "type": "object",
          "required": ["MemoryDepositionEngineV7", "runtimeStepEventBus", "postToolWritebackAutocapture", "appendOnlyDepositionLedger", "memoryEventHashBinding", "claimCompactResumeBinding"],
          "properties": {
            "MemoryDepositionEngineV7": { "const": true },
            "runtimeStepEventBus": { "const": true },
            "postToolWritebackAutocapture": { "const": true },
            "appendOnlyDepositionLedger": { "const": true },
            "memoryEventHashBinding": { "const": true },
            "claimCompactResumeBinding": { "const": true, "description": "claim_compact_resume_binding" }
          },
          "additionalProperties": false
        },
        "nextCommands": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
