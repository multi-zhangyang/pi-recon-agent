    "invariants"
  ],
  "properties": {
    "kind": { "const": "repi-agent-dogfood-structured-claims-fixture" },
    "schemaVersion": { "const": 1 },
    "AgentDogfoodStructuredClaimMergeGateV1": { "const": true },
    "requiredGates": {
      "type": "array",
      "items": { "$ref": "#/$defs/AgentDogfoodStructuredClaimRequiredGateV1" },
      "minItems": 8,
      "uniqueItems": true
    },
    "structuredClaimMerge": { "$ref": "#/$defs/AgentDogfoodStructuredClaimMergeV1" },
    "negativeCases": {
      "type": "array",
      "items": { "$ref": "#/$defs/AgentDogfoodStructuredClaimNegativeCaseV1" },
      "minItems": 5
    },
    "invariants": {
