      "items": { "type": "string" },
      "minItems": 8,
      "uniqueItems": true
    }
  },
  "$defs": {
    "AgentDogfoodStructuredClaimMergeGateV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "AgentDogfoodStructuredClaimMergeGateV1",
        "requiredGates",
        "structuredClaimMerge",
        "negativeCases",
        "invariants"
      ],
      "properties": {
        "kind": { "const": "repi-agent-dogfood-structured-claims-fixture" },
        "schemaVersion": { "const": 1 },
        "AgentDogfoodStructuredClaimMergeGateV1": { "const": true },
        "requiredGates": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentDogfoodStructuredClaimRequiredGateV1" },
          "minItems": 8,
          "uniqueItems": true
        },
        "structuredClaimMerge": { "$ref": "#/$defs/AgentDogfoodStructuredClaimMergeV1" },
        "negativeCases": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentDogfoodStructuredClaimNegativeCaseV1" },
          "minItems": 5
        },
        "invariants": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 8,
          "uniqueItems": true
        }
      },
      "x-repiInvariants": [
        "agent_dogfood_structured_claim_merge_gate",
        "agent_dogfood_structured_claim_merge",
        "narrative_only_observation_never_promotes",
        "final_pass_requires_json_query",
        "final_pass_requires_verifier",
        "unresolved_challenge_blocks_final",
        "claim_ledger_events_reference_structured_claims",
        "runtime_manifest_artifact_ref_required"
      ]
    },
    "AgentDogfoodStructuredClaimRequiredGateV1": {
      "enum": [
        "AgentDogfoodStructuredClaimMergeGateV1",
        "agent_dogfood_structured_claim_merge",
        "narrative_only_observation_never_promotes",
        "final_pass_requires_json_query",
        "final_pass_requires_verifier",
        "unresolved_challenge_blocks_final",
        "claim_ledger_events_reference_structured_claims",
        "runtime_manifest_artifact_ref_required"
      ]
    },
    "ArtifactRefV1": {
      "type": "object",
      "required": ["artifactId", "path", "sha256", "jsonQuery", "op", "expected", "verifierPass"],
      "properties": {
        "artifactId": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{32,64}$" },
        "jsonQuery": { "type": "string", "minLength": 1 },
        "op": { "enum": ["==", "contains", "includes_all"] },
        "expected": {},
        "verifierPass": { "type": "boolean" }
      }
    },
    "ChallengeV1": {
      "type": "object",
      "required": ["challengeId", "status"],
      "properties": {
        "challengeId": { "type": "string", "minLength": 1 },
        "status": { "enum": ["open", "resolved"] },
        "resolution": { "type": "string" }
      }
    },
    "ClaimRowV1": {
      "type": "object",
      "required": ["claimId", "workerId", "mergeKey", "status", "statement", "artifactRefs", "challenges", "promotionBoundary"],
      "properties": {
        "claimId": { "type": "string", "minLength": 1 },
        "workerId": { "type": "string", "minLength": 1 },
        "mergeKey": { "type": "string", "minLength": 1 },
        "status": { "enum": ["proven", "gap", "pending", "blocked"] },
        "statement": { "type": "string", "minLength": 1 },
        "artifactRefs": { "type": "array", "items": { "$ref": "#/$defs/ArtifactRefV1" } },
        "challenges": { "type": "array", "items": { "$ref": "#/$defs/ChallengeV1" } },
        "promotionBoundary": { "type": "string", "minLength": 1 }
      }
    },
    "AgentDogfoodStructuredClaimMergeV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "mergeId", "sourcePoolId", "claimRows", "conflictTable", "promotionGate"],
      "properties": {
        "kind": { "const": "StructuredClaimMergeV1" },
        "schemaVersion": { "const": 1 },
        "mergeId": { "type": "string", "minLength": 1 },
        "sourcePoolId": { "type": "string", "minLength": 1 },
        "claimRows": { "type": "array", "items": { "$ref": "#/$defs/ClaimRowV1" }, "minItems": 1 },
        "conflictTable": { "type": "array" },
        "promotionGate": {
          "type": "object",
          "required": ["mode", "requiredStatuses", "finalClaims", "blockedClaims", "policies"],
          "properties": {
            "mode": { "const": "strict_final_claim_promotion" },
            "requiredStatuses": { "type": "array", "contains": { "const": "proven" } },
            "finalClaims": { "type": "array" },
            "blockedClaims": { "type": "array" },
            "policies": {
              "type": "array",
              "contains": { "const": "narrative_only_observation_never_promotes" }
            }
          }
        }
      }
    },
    "AgentDogfoodStructuredClaimNegativeCaseV1": {
      "type": "object",
      "required": ["id", "mutates", "expect", "mustNotPromote"],
      "properties": {
        "id": {
          "enum": [
            "narrative-only-final-pass",
            "missing-json-query",
            "verifier-false-final-pass",
            "unresolved-challenge-final-pass",
            "missing-runtime-manifest-artifact-ref"
          ]
        },
        "mutates": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "expect": { "const": "fail" },
        "mustNotPromote": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    }
  },
  "x-repiInvariants": [
    "agent_dogfood_structured_claim_merge_gate",
