{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/relane-specialist-command-pack.schema.json",
  "title": "ReLaneSpecialistCommandPackGateV1",
  "description": "relane_specialist_command_pack_gate / route_to_domain_lane_seed_matrix / domain_lane_command_pack_markers / specialist_evidence_analyzer_anchor_matrix / self_heal_command_fallback_matrix / proof_exit_bridge_matrix / runtime:re_lane-specialist-command-pack / re_lane_specialist_pack",
  "$defs": {
    "ReLaneSpecialistDomainPackV1": {
      "type": "object",
      "required": ["domainId", "routeMatchers", "laneSeeds", "commandPackMarkers", "analyzerAnchors", "selfHealCommands", "proofExitBridge", "status", "gaps"],
      "properties": {
        "domainId": { "type": "string" },
        "routeMatchers": { "type": "array", "minItems": 2, "items": { "type": "string" } },
        "laneSeeds": { "type": "array", "minItems": 2, "items": { "type": "string" } },
        "commandPackMarkers": { "type": "array", "minItems": 3, "items": { "type": "string" } },
        "analyzerAnchors": { "type": "array", "minItems": 3, "items": { "type": "string" } },
        "selfHealCommands": { "type": "array", "minItems": 2, "items": { "type": "string" } },
        "proofExitBridge": { "type": "array", "minItems": 3, "items": { "type": "string" } },
        "status": { "enum": ["ready", "blocked"] },
        "gaps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ReLaneSpecialistCommandPackGateV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "generatedAt", "ReLaneSpecialistCommandPackGateV1", "runtime", "requiredGates", "domainCount", "readyDomainCount", "rows", "closure", "nextRuntimeCommands", "negativeCases", "invariants"],
      "properties": {
        "kind": { "const": "ReLaneSpecialistCommandPackGateV1" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string" },
        "ReLaneSpecialistCommandPackGateV1": { "const": true },
        "runtime": { "const": "runtime:re_lane-specialist-command-pack" },
        "requiredGates": { "type": "array", "items": { "type": "string" } },
        "domainCount": { "type": "integer", "minimum": 15 },
        "readyDomainCount": { "type": "integer", "minimum": 15 },
        "rows": { "type": "array", "minItems": 15, "items": { "$ref": "#/$defs/ReLaneSpecialistDomainPackV1" } },
        "closure": {
          "type": "object",
          "required": ["allDomainsHaveRouteMatchers", "allDomainsHaveLaneSeeds", "allDomainsHaveCommandPacks", "allDomainsHaveAnalyzerAnchors", "allDomainsHaveSelfHeal", "allDomainsHaveProofExitBridge"],
          "properties": {
            "allDomainsHaveRouteMatchers": { "const": true },
            "allDomainsHaveLaneSeeds": { "const": true },
            "allDomainsHaveCommandPacks": { "const": true },
            "allDomainsHaveAnalyzerAnchors": { "const": true },
            "allDomainsHaveSelfHeal": { "const": true },
            "allDomainsHaveProofExitBridge": { "const": true }
          }
        },
        "nextRuntimeCommands": { "type": "array", "items": { "type": "string" } },
        "negativeCases": { "type": "array", "items": { "type": "object" } },
        "invariants": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$ref": "#/$defs/ReLaneSpecialistCommandPackGateV1"
}
