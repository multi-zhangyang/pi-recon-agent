{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/memory-experience.schema.json",
  "title": "REPI Memory Experience Engine V8",
  "description": "MemoryExperienceEngineV8 converts raw memory/deposition events into Episode -> Claim -> Lesson -> Promotion artifacts with contradiction resolution and usefulness backpropagation.",
  "$defs": {
    "ArtifactRef": {
      "type": "object",
      "required": ["path", "sha256", "tier"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": ["string", "null"] },
        "tier": { "type": "string" },
        "required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "Quality": {
      "type": "object",
      "required": ["confidence", "replayVerified", "reuseCount", "failureCount", "lastUsefulAt", "decay"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "replayVerified": { "type": "boolean" },
        "reuseCount": { "type": "integer", "minimum": 0 },
        "failureCount": { "type": "integer", "minimum": 0 },
        "lastUsefulAt": { "type": "string" },
        "decay": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "MemoryExperienceEpisodeV8": {
      "type": "object",
      "required": ["kind", "schemaVersion", "id", "ts", "MemoryExperienceEngineV8", "eventId", "depositionEventIds", "caseSignature", "route", "targetScope", "intent", "outcome", "observation", "commands", "evidenceRefs", "quality", "claimIds", "lessonIds", "entryHash"],
      "properties": {
        "kind": { "const": "repi-memory-experience-episode" },
        "schemaVersion": { "const": 1 },
        "id": { "type": "string", "minLength": 1 },
        "ts": { "type": "string" },
        "MemoryExperienceEngineV8": { "const": true },
        "eventId": { "type": "string" },
        "depositionEventIds": { "type": "array", "items": { "type": "string" } },
        "caseSignature": { "type": "string" },
        "route": { "type": "string" },
        "target": { "type": "string" },
        "targetScope": { "type": "string" },
        "intent": { "type": "string" },
        "outcome": { "enum": ["success", "failure", "partial", "blocked", "repair"] },
        "observation": { "type": "string" },
        "commands": { "type": "array", "items": { "type": "string" } },
        "evidenceRefs": { "type": "array", "items": { "$ref": "#/$defs/ArtifactRef" } },
        "failureSignature": { "type": "string" },
        "quality": { "$ref": "#/$defs/Quality" },
        "claimIds": { "type": "array", "items": { "type": "string" } },
        "lessonIds": { "type": "array", "items": { "type": "string" } },
        "entryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "MemoryExperienceClaimV8": {
      "type": "object",
      "required": ["kind", "schemaVersion", "id", "ts", "MemoryExperienceEngineV8", "episodeId", "eventId", "claimType", "status", "statement", "caseSignature", "route", "targetScope", "supportEventIds", "contradictionEventIds", "evidenceRefs", "confidence", "reuseScore", "promotionReady", "blockers", "entryHash"],
      "properties": {
        "kind": { "const": "repi-memory-experience-claim" },
        "schemaVersion": { "const": 1 },
        "id": { "type": "string" },
        "ts": { "type": "string" },
        "MemoryExperienceEngineV8": { "const": true },
        "episodeId": { "type": "string" },
        "eventId": { "type": "string" },
        "claimType": { "enum": ["command_strategy", "failure_signature", "verifier_rule", "artifact_pattern", "scope_constraint", "repair_playbook"] },
        "status": { "enum": ["candidate", "promoted", "retained", "demoted", "quarantined", "conflicted"] },
        "statement": { "type": "string" },
        "caseSignature": { "type": "string" },
        "route": { "type": "string" },
        "targetScope": { "type": "string" },
        "commandFingerprint": { "type": "string" },
        "supportEventIds": { "type": "array", "items": { "type": "string" } },
        "contradictionEventIds": { "type": "array", "items": { "type": "string" } },
        "evidenceRefs": { "type": "array", "items": { "$ref": "#/$defs/ArtifactRef" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reuseScore": { "type": "number" },
        "promotionReady": { "type": "boolean" },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "entryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "MemoryExperienceLessonV8": {
      "type": "object",
      "required": ["kind", "schemaVersion", "id", "ts", "MemoryExperienceEngineV8", "claimId", "episodeId", "action", "lesson", "appliesWhen", "commands", "confidence", "backprop", "evidenceRefs"],
      "properties": {
        "kind": { "const": "repi-memory-experience-lesson" },
        "schemaVersion": { "const": 1 },
        "id": { "type": "string" },
        "ts": { "type": "string" },
        "MemoryExperienceEngineV8": { "const": true },
        "claimId": { "type": "string" },
        "episodeId": { "type": "string" },
        "action": { "enum": ["reuse", "avoid", "repair", "verify", "scope-limit"] },
        "lesson": { "type": "string" },
        "appliesWhen": { "type": "array", "items": { "type": "string" } },
        "commands": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "backprop": {
          "type": "object",
          "required": ["reuseCount", "failureCount", "decay", "lastUsefulAt", "source"],
          "properties": {
            "reuseCount": { "type": "integer", "minimum": 0 },
            "failureCount": { "type": "integer", "minimum": 0 },
            "decay": { "type": "number", "minimum": 0 },
            "lastUsefulAt": { "type": "string" },
            "source": { "type": "string" }
          },
          "additionalProperties": false
        },
        "evidenceRefs": { "type": "array", "items": { "$ref": "#/$defs/ArtifactRef" } }
      },
      "additionalProperties": false
    },
    "MemoryExperienceReportV8": {
      "type": "object",
      "required": ["kind", "schemaVersion", "generatedAt", "MemoryExperienceEngineV8", "episode_model_v8", "structured_claim_extraction", "lesson_promotion_gate", "contradiction_resolution", "usefulness_backprop", "reportPath", "episodesPath", "claimsPath", "lessonBookPath", "promotionLedgerPath", "memoryEventsPath", "depositionEventBusPath", "episodeCount", "claimCount", "lessonCount", "promotionDecisionCount", "promotedClaimIds", "retainedClaimIds", "demotedClaimIds", "quarantinedClaimIds", "conflictedClaimIds", "operatorInjectionCommands", "avoidCommands", "verifyCommands", "promotionCoverage", "status", "recentEpisodes", "recentClaims", "recentLessons", "requiredGates", "policy", "nextCommands"],
      "properties": {
        "kind": { "const": "repi-memory-experience-report" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "MemoryExperienceEngineV8": { "const": true },
        "episode_model_v8": { "const": true },
        "structured_claim_extraction": { "const": true },
        "lesson_promotion_gate": { "const": true },
        "contradiction_resolution": { "const": true },
        "usefulness_backprop": { "const": true },
        "reportPath": { "type": "string" },
        "episodesPath": { "type": "string" },
        "claimsPath": { "type": "string" },
        "lessonBookPath": { "type": "string" },
        "promotionLedgerPath": { "type": "string" },
        "memoryEventsPath": { "type": "string" },
        "depositionEventBusPath": { "type": "string" },
        "episodeCount": { "type": "integer", "minimum": 0 },
        "claimCount": { "type": "integer", "minimum": 0 },
        "lessonCount": { "type": "integer", "minimum": 0 },
        "promotionDecisionCount": { "type": "integer", "minimum": 0 },
        "promotedClaimIds": { "type": "array", "items": { "type": "string" } },
        "retainedClaimIds": { "type": "array", "items": { "type": "string" } },
        "demotedClaimIds": { "type": "array", "items": { "type": "string" } },
        "quarantinedClaimIds": { "type": "array", "items": { "type": "string" } },
        "conflictedClaimIds": { "type": "array", "items": { "type": "string" } },
        "operatorInjectionCommands": { "type": "array", "items": { "type": "string" } },
        "avoidCommands": { "type": "array", "items": { "type": "string" } },
        "verifyCommands": { "type": "array", "items": { "type": "string" } },
        "promotionCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "enum": ["pass", "warn", "blocked", "empty"] },
        "recentEpisodes": { "type": "array", "items": { "$ref": "#/$defs/MemoryExperienceEpisodeV8" } },
        "recentClaims": { "type": "array", "items": { "$ref": "#/$defs/MemoryExperienceClaimV8" } },
        "recentLessons": { "type": "array", "items": { "$ref": "#/$defs/MemoryExperienceLessonV8" } },
        "requiredGates": { "type": "array", "items": { "type": "string" } },
        "policy": {
          "type": "object",
          "required": ["MemoryExperienceEngineV8", "episodeModel", "structuredClaimExtraction", "lessonPromotionGate", "contradictionResolution", "usefulnessBackprop", "scopeSafeInjectionOnly"],
          "properties": {
            "MemoryExperienceEngineV8": { "const": true },
            "episodeModel": { "const": true },
            "structuredClaimExtraction": { "const": true },
            "lessonPromotionGate": { "const": true },
            "contradictionResolution": { "const": true },
            "usefulnessBackprop": { "const": true },
            "scopeSafeInjectionOnly": { "const": true }
          },
          "additionalProperties": false
        },
        "nextCommands": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
