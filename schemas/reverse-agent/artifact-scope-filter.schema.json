{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/artifact-scope-filter.schema.json",
  "title": "REPI Artifact Scope Filter Contract",
  "description": "ArtifactScopeFilterV1 closes latest-artifact side-channel reuse by applying MemoryScopeIsolationV1 to context/artifact lookup paths before they bypass KnowledgeScopeIsolationV1.",
  "$defs": {
    "ArtifactScopeFilterDecisionV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "path", "artifactKind", "requestedBy", "verdict", "reasons", "blocksArtifactReuse", "recommendedAction", "matchedBy"],
      "properties": {
        "kind": { "const": "repi-artifact-scope-filter-decision" },
        "schemaVersion": { "const": 1 },
        "path": { "type": "string", "minLength": 1 },
        "artifactKind": { "type": "string", "minLength": 1 },
        "requestedBy": { "type": "string", "minLength": 1 },
        "eventId": { "type": "string" },
        "caseSignature": { "type": "string" },
        "verdict": { "enum": ["allow", "warn", "block"] },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "blocksArtifactReuse": { "type": "boolean" },
        "recommendedAction": { "enum": ["allow", "retain", "quarantine", "manual-review"] },
        "matchedBy": { "enum": ["artifact-hash", "text-reference", "untracked"] }
      },
      "additionalProperties": true
    },
    "ArtifactScopeFilterV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "ArtifactScopeFilterV1",
        "MemoryScopeIsolationV1",
        "latest_artifact_side_channel_scope_filter",
        "reportPath",
        "requestedBy",
        "currentScope",
        "checkedArtifactCount",
        "blockedArtifactCount",
        "warnArtifactCount",
        "allowedArtifactCount",
        "quarantinedArtifacts",
        "decisions",
        "requiredGates"
      ],
      "properties": {
        "kind": { "const": "repi-artifact-scope-filter-report" },
        "schemaVersion": { "const": 1 },
        "ArtifactScopeFilterV1": { "const": true },
        "MemoryScopeIsolationV1": { "const": true },
        "latest_artifact_side_channel_scope_filter": { "const": true },
        "reportPath": { "type": "string", "minLength": 1 },
        "requestedBy": { "type": "string", "minLength": 1 },
        "currentScope": { "type": "object" },
        "checkedArtifactCount": { "type": "integer", "minimum": 0 },
        "blockedArtifactCount": { "type": "integer", "minimum": 0 },
        "warnArtifactCount": { "type": "integer", "minimum": 0 },
        "allowedArtifactCount": { "type": "integer", "minimum": 0 },
        "quarantinedArtifacts": { "type": "array", "items": { "type": "string" } },
        "warnArtifacts": { "type": "array", "items": { "type": "string" } },
        "allowedArtifacts": { "type": "array", "items": { "type": "string" } },
        "decisions": { "type": "array", "items": { "$ref": "#/$defs/ArtifactScopeFilterDecisionV1" } },
        "requiredGates": {
          "type": "array",
          "contains": { "const": "latest_artifact_side_channel_scope_filter" }
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    { "$comment": "ArtifactScopeFilterV1" },
    { "$comment": "MemoryScopeIsolationV1" },
    { "$comment": "latest_artifact_side_channel_scope_filter" },
    { "$comment": "blocked_latest_artifact_quarantined" },
    { "$comment": "context_artifact_index_excludes_scope_blocked_artifacts" },
    { "$comment": "artifact_scope_filter_report_in_context_pack" }
  ]
}
