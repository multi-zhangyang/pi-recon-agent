{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/repair-rollback-policy.schema.json",
  "title": "RepairRollbackPolicyV1",
  "description": "baseline_required_before_repair, allowlist_violation_blocks_repair, rollback_tree_hash_must_match_baseline, regression_gates_required_after_repair_and_restore",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "generatedAt",
    "source",
    "workspace",
    "baseline",
    "allowlist",
    "repair",
    "rollback",
    "regression",
    "failureLedgerEvents",
    "repairQueue",
    "failureRepairValidation",
    "assertions"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "RepairRollbackPolicyV1" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string" },
    "source": { "enum": ["re_autofix", "re_operator", "re_proof_loop", "compound-frontier", "provider-worker"] },
    "workspace": { "type": "string" },
    "baseline": {
      "type": "object",
      "required": ["command", "treeSha256", "files"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string" },
        "treeSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "bytes", "sha256"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "bytes": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        }
      }
    },
    "allowlist": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "repair": {
      "type": "object",
      "required": ["commands", "changedFiles", "expectedArtifacts", "regressionGates"],
      "additionalProperties": false,
      "properties": {
        "commands": { "type": "array", "items": { "type": "string" } },
        "changedFiles": { "type": "array", "items": { "type": "string" } },
        "expectedArtifacts": { "type": "array", "items": { "type": "string" } },
        "regressionGates": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "rollback": {
      "type": "object",
      "required": ["required", "commands", "restored", "restoredTreeSha256", "criteria"],
      "additionalProperties": false,
      "properties": {
        "required": { "const": true },
        "commands": { "type": "array", "items": { "type": "string" } },
        "restored": { "type": "boolean" },
        "restoredTreeSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "regression": {
      "type": "object",
      "required": ["before", "after", "restored", "gates"],
      "additionalProperties": false,
      "properties": {
        "before": { "enum": ["pass", "fail", "skipped"] },
        "after": { "enum": ["pass", "fail", "skipped"] },
        "restored": { "enum": ["pass", "fail", "skipped"] },
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["gateId", "command", "status"],
            "additionalProperties": true,
            "properties": {
              "gateId": { "type": "string" },
              "command": { "type": "string" },
              "status": { "enum": ["pass", "fail", "skipped"] }
            }
          }
        }
      }
    },
    "failureLedgerEvents": { "type": "array", "minItems": 1 },
    "repairQueue": { "type": "array", "minItems": 1 },
    "failureRepairValidation": {
      "type": "object",
      "required": ["ok", "failureCount", "repairCount"],
      "additionalProperties": true,
      "properties": {
        "ok": { "type": "boolean" },
        "failureCount": { "type": "integer", "minimum": 1 },
        "repairCount": { "type": "integer", "minimum": 1 }
      }
    },
    "assertions": {
      "type": "object",
      "required": ["baselineCaptured", "allowlistEnforced", "rollbackRestored", "regressionGatesPassed", "noUnrelatedFileChanges", "failureRepairLinked"],
      "additionalProperties": false,
      "properties": {
        "baselineCaptured": { "type": "boolean" },
        "allowlistEnforced": { "type": "boolean" },
        "rollbackRestored": { "type": "boolean" },
        "regressionGatesPassed": { "type": "boolean" },
        "noUnrelatedFileChanges": { "type": "boolean" },
        "failureRepairLinked": { "type": "boolean" }
      }
    }
  },
  "x-repiStrictFixture": "fixtures/reverse-agent/repair-rollback-policy.fixture.json",
  "x-repiInvariants": [
    "baseline_required_before_repair",
    "allowlist_violation_blocks_repair",
    "rollback_tree_hash_must_match_baseline",
    "regression_gates_required_after_repair_and_restore",
    "failure_repair_ledger_links_rollback_queue"
  ]
}
