{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/toolchain-domain-capability.schema.json",
  "title": "ToolchainDomainCapabilityV1",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "generatedAt",
    "runtime",
    "domains",
    "coverage",
    "toolchainClosure"
  ],
  "properties": {
    "kind": {
      "const": "ToolchainDomainCapabilityV1"
    },
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "runtime": {
      "const": "runtime:toolchain-doctor"
    },
    "discoveryMode": {
      "enum": [
        "command-v",
        "tool-index",
        "hybrid"
      ]
    },
    "domains": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "required": [
          "domainId",
          "status",
          "requiredAny",
          "preferred",
          "fallbacks",
          "presentRequired",
          "presentFallbacks",
          "fallback_available",
          "critical_gap",
          "playbookMarkersFound",
          "commandScaffoldsFound",
          "nextRuntimeCommands"
        ],
        "properties": {
          "domainId": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "enum": [
              "ready",
              "degraded",
              "blocked"
            ]
          },
          "requiredAny": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preferred": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fallbacks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "presentRequired": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "presentPreferred": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "presentFallbacks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingRequired": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingPreferred": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fallback_available": {
            "type": "boolean"
          },
          "critical_gap": {
            "type": "boolean"
          },
          "playbookMarkersFound": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "playbookMarkersMissing": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "commandScaffoldsFound": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "commandScaffoldsMissing": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proofExit": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommendedInstallHints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "nextRuntimeCommands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": [
        "domainCount",
        "readyCount",
        "degradedCount",
        "blockedCount",
        "readyOrDegradedCount"
      ],
      "properties": {
        "domainCount": {
          "type": "integer"
        },
        "readyCount": {
          "type": "integer"
        },
        "degradedCount": {
          "type": "integer"
        },
        "blockedCount": {
          "type": "integer"
        },
        "readyOrDegradedCount": {
          "type": "integer"
        },
        "fallbackDomainCount": {
          "type": "integer"
        }
      }
    },
    "toolchainClosure": {
      "type": "object",
      "required": [
        "allDomainsHaveFallback",
        "allDomainsHavePlaybookMarkers",
        "allDomainsHaveCommandScaffolds",
        "noCriticalGap"
      ],
      "properties": {
        "allDomainsHaveRuntimeBackedDiscovery": {
          "type": "boolean"
        },
        "allDomainsHaveFallback": {
          "type": "boolean"
        },
        "allDomainsHavePlaybookMarkers": {
          "type": "boolean"
        },
        "allDomainsHaveCommandScaffolds": {
          "type": "boolean"
        },
        "noCriticalGap": {
          "type": "boolean"
        }
      }
    }
  },
  "description": "domain_toolchain_matrix domain:web-api domain:rev-native domain:pwn domain:mobile domain:pcap-dfir domain:firmware-iot fallback_available critical_gap runtime:toolchain-doctor"
}
