{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/memory-maturation-runtime.schema.json",
  "title": "MemoryMaturationRuntimeV15",
  "description": "REPI MemoryMaturationRuntimeV15 report: automatic_memory_maturation_pipeline from tool_result_to_strategy_loop to closed_loop_writeback.",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "MemoryMaturationRuntimeV15",
    "automatic_memory_maturation_pipeline",
    "tool_result_to_strategy_loop",
    "closed_loop_writeback",
    "retention_decay_scheduler",
    "stale_memory_rehearsal_queue",
    "usefulness_backprop_to_maturation",
    "promotion_demotion_replay_backed",
    "cross_session_maturation_ready",
    "reportPath",
    "ledgerPath",
    "actionBoardPath",
    "rowCount",
    "status",
    "rows",
    "requiredGates"
  ],
  "properties": {
    "kind": {
      "const": "repi-memory-maturation-runtime-report"
    },
    "schemaVersion": {
      "const": 1
    },
    "MemoryMaturationRuntimeV15": {
      "const": true
    },
    "automatic_memory_maturation_pipeline": {
      "const": true
    },
    "tool_result_to_strategy_loop": {
      "const": true
    },
    "closed_loop_writeback": {
      "const": true
    },
    "promotion_demotion_replay_backed": {
      "const": true
    },
    "cross_session_maturation_ready": {
      "const": true
    },
    "reportPath": {
      "type": "string",
      "pattern": "maturation-runtime-report\\.json$"
    },
    "ledgerPath": {
      "type": "string",
      "pattern": "maturation-runtime-ledger\\.jsonl$"
    },
    "actionBoardPath": {
      "type": "string",
      "pattern": "maturation-action-board\\.md$"
    },
    "sourceActiveKernelReportPath": {
      "type": "string"
    },
    "rowCount": {
      "type": "integer",
      "minimum": 0
    },
    "promotedEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retainedEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "demotedEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quarantinedEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pendingFeedbackEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replayRequiredEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operatorCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "feedbackCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "maturationCoverage": {
      "type": "number",
      "minimum": 0
    },
    "status": {
      "enum": [
        "pass",
        "warn",
        "blocked",
        "empty"
      ]
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MemoryMaturationRowV15"
      }
    },
    "requiredGates": {
      "type": "array",
      "contains": {
        "const": "MemoryMaturationRuntimeV15"
      }
    },
    "retention_decay_scheduler": {
      "const": true
    },
    "stale_memory_rehearsal_queue": {
      "const": true
    },
    "usefulness_backprop_to_maturation": {
      "const": true
    },
    "retentionQueueEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expiredEventIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retentionCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "MemoryMaturationRowV15": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "MemoryMaturationRuntimeV15",
        "automatic_memory_maturation_pipeline",
        "tool_result_to_strategy_loop",
        "closed_loop_writeback",
        "usefulness_backprop_to_maturation",
        "stale_memory_rehearsal_queue",
        "retention_decay_scheduler",
        "action",
        "retentionAction",
        "stagePath",
        "sourceEventIds",
        "maturityScore",
        "lastUsefulAt",
        "decayPenalty",
        "stalenessDays",
        "retentionScore",
        "prevHash",
        "retentionCommands",
        "entryHash"
      ],
      "properties": {
        "kind": {
          "const": "repi-memory-maturation-row"
        },
        "schemaVersion": {
          "const": 1
        },
        "MemoryMaturationRuntimeV15": {
          "const": true
        },
        "automatic_memory_maturation_pipeline": {
          "const": true
        },
        "tool_result_to_strategy_loop": {
          "const": true
        },
        "closed_loop_writeback": {
          "const": true
        },
        "action": {
          "enum": [
            "promote",
            "retain",
            "demote",
            "quarantine",
            "feedback-required",
            "replay-required"
          ]
        },
        "stagePath": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "sourceEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maturityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "prevHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "entryHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "retention_decay_scheduler": {
          "const": true
        },
        "stale_memory_rehearsal_queue": {
          "const": true
        },
        "usefulness_backprop_to_maturation": {
          "const": true
        },
        "retentionAction": {
          "enum": [
            "keep",
            "rehearse",
            "decay",
            "expire",
            "quarantine",
            "feedback"
          ]
        },
        "retentionScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "stalenessDays": {
          "type": "number",
          "minimum": 0
        },
        "decayPenalty": {
          "type": "number",
          "minimum": 0
        },
        "lastUsefulAt": {
          "type": "string"
        },
        "retentionCommands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
