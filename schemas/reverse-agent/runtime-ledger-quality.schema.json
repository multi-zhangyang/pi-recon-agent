{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/runtime-ledger-quality.schema.json",
  "title": "RuntimeLedgerQualityGateV1",
  "description": "REPI RuntimeLedgerQualityGateV1 requires each runtime ClaimLedgerEventV1 source to preserve artifact hashes, event type counts, tip hash, hash-chain status, and strict validator results before promotion.",
  "type": "object",
  "required": ["kind", "schemaVersion", "generatedAt", "ok", "sources", "requiredSources", "qualityPolicy"],
  "additionalProperties": true,
  "properties": {
    "kind": { "const": "repi-runtime-ledger-quality-gate" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string" },
    "ok": { "type": "boolean" },
    "requiredSources": {
      "type": "array",
      "minItems": 3,
      "items": { "enum": ["agent-dogfood", "re_swarm", "compound-frontier"] }
    },
    "qualityPolicy": {
      "type": "object",
      "required": ["requireHashChain", "requireAllEventTypes", "requireTipHash", "requireArtifactSha256", "requireStrictValidator", "requiredEventTypes"],
      "additionalProperties": false,
      "properties": {
        "requireHashChain": { "const": true },
        "requireAllEventTypes": { "const": true },
        "requireTipHash": { "const": true },
        "requireArtifactSha256": { "const": true },
        "requireStrictValidator": { "const": true },
        "requiredEventTypes": {
          "type": "array",
          "prefixItems": [
            { "const": "artifact_handoff" },
            { "const": "claim" },
            { "const": "validation" },
            { "const": "challenge" },
            { "const": "resolution" }
          ],
          "minItems": 5,
          "maxItems": 5
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/sourceQuality" }
    }
  },
  "$defs": {
    "sourceQuality": {
      "type": "object",
      "required": ["source", "status", "hashChainOk", "runtimeClaimLedgerCaptured", "eventCount", "tipHash", "eventTypeCounts", "artifactDigests", "strictValidator"],
      "additionalProperties": true,
      "properties": {
        "source": { "enum": ["adapter-fixture", "agent-dogfood", "re_swarm", "compound-frontier"] },
        "status": { "type": "string" },
        "hashChainOk": { "type": "boolean" },
        "runtimeClaimLedgerCaptured": { "type": "boolean" },
        "eventCount": { "type": "integer", "minimum": 5 },
        "tipHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "eventTypeCounts": {
          "type": "object",
          "required": ["artifact_handoff", "claim", "validation", "challenge", "resolution"],
          "properties": {
            "artifact_handoff": { "type": "integer", "minimum": 1 },
            "claim": { "type": "integer", "minimum": 1 },
            "validation": { "type": "integer", "minimum": 1 },
            "challenge": { "type": "integer", "minimum": 1 },
            "resolution": { "type": "integer", "minimum": 1 }
          }
        },
        "artifactDigests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "exists", "sha256"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "exists": { "const": true },
              "bytes": { "type": "integer", "minimum": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "strictValidator": {
          "type": "object",
          "required": ["allowPlatformGapsOk", "strictClaimsOk", "allowPlatformGapsStdoutSha256", "strictClaimsStdoutSha256", "requiredGaps"],
          "properties": {
            "allowPlatformGapsOk": { "const": true },
            "strictClaimsOk": { "const": true },
            "allowPlatformGapsStdoutSha256": { "type": "string", "minLength": 8 },
            "strictClaimsStdoutSha256": { "type": "string", "minLength": 8 },
            "requiredGaps": { "type": "array", "maxItems": 0 }
          }
        }
      }
    }
  }
}
