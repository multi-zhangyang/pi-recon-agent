#!/usr/bin/env bash
set -euo pipefail

INVOKED_SOURCE="${BASH_SOURCE[0]}"
SOURCE="$INVOKED_SOURCE"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then SOURCE="$DIR/$TARGET"; else SOURCE="$TARGET"; fi
done
ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"
if [ -z "${REPI_INSTALLED_BIN_PATH:-}" ]; then
  if [[ "$INVOKED_SOURCE" == */* ]]; then
    case "$INVOKED_SOURCE" in
      /*) export REPI_INSTALLED_BIN_PATH="$INVOKED_SOURCE" ;;
      *) export REPI_INSTALLED_BIN_PATH="$(cd -P "$(dirname "$INVOKED_SOURCE")" 2>/dev/null && pwd)/$(basename "$INVOKED_SOURCE")" ;;
    esac
  else
    FOUND_REPI="$(command -v "$INVOKED_SOURCE" 2>/dev/null || true)"
    export REPI_INSTALLED_BIN_PATH="${FOUND_REPI:-$SOURCE}"
  fi
fi

# REPI is the independent product entrypoint. It never owns the
# upstream `pi` command and keeps all runtime state in ~/.repi/agent.
# Active reverse/pentest execution entry.
export REPI_CODING_AGENT_APP_NAME="${REPI_CODING_AGENT_APP_NAME:-repi}"
export REPI_CODING_AGENT_CONFIG_DIR="${REPI_CODING_AGENT_CONFIG_DIR:-.repi}"
export REPI_CODING_AGENT_DIR="${REPI_CODING_AGENT_DIR:-${REPI_AGENT_DIR:-$HOME/.repi/agent}}"
export REPI_CODING_AGENT_SESSION_DIR="${REPI_CODING_AGENT_SESSION_DIR:-$REPI_CODING_AGENT_DIR/sessions}"
export REPI_PRIMARY=1
export REPI_PRODUCT=1
export REPI_SKIP_VERSION_CHECK="${REPI_SKIP_VERSION_CHECK:-1}"
export REPI_SKIP_PACKAGE_UPDATE_CHECK="${REPI_SKIP_PACKAGE_UPDATE_CHECK:-1}"
export REPI_TELEMETRY="${REPI_TELEMETRY:-0}"
export REPI_OFFLINE="${REPI_OFFLINE:-0}"
export REPI_PRINT_PROGRESS="${REPI_PRINT_PROGRESS:-1}"
export REPI_PRINT_TIMEOUT_MS="${REPI_PRINT_TIMEOUT_MS:-210000}"
export REPI_PRINT_TIMEOUT_GRACE_MS="${REPI_PRINT_TIMEOUT_GRACE_MS:-30000}"
export REPI_PRINT_TIMEOUT_TOOL_GRACE_MS="${REPI_PRINT_TIMEOUT_TOOL_GRACE_MS:-300000}"
export REPI_PRINT_MAX_TURNS="${REPI_PRINT_MAX_TURNS:-10}"
export REPI_PRINT_MAX_TOOL_CALLS="${REPI_PRINT_MAX_TOOL_CALLS:-48}"
export REPI_STDIN_READ_TIMEOUT_MS="${REPI_STDIN_READ_TIMEOUT_MS:-1500}"
export REPI_BASH_DEFAULT_TIMEOUT_SECONDS="${REPI_BASH_DEFAULT_TIMEOUT_SECONDS:-120}"
export REPI_DEFAULT_THINKING="${REPI_DEFAULT_THINKING:-medium}"
# Compatibility for inherited upstream internals; user-facing REPI docs prefer REPI_* names.
export PI_SKIP_VERSION_CHECK="${PI_SKIP_VERSION_CHECK:-$REPI_SKIP_VERSION_CHECK}"
export PI_SKIP_PACKAGE_UPDATE_CHECK="${PI_SKIP_PACKAGE_UPDATE_CHECK:-$REPI_SKIP_PACKAGE_UPDATE_CHECK}"
export PI_TELEMETRY="${PI_TELEMETRY:-$REPI_TELEMETRY}"
export PI_OFFLINE="${PI_OFFLINE:-$REPI_OFFLINE}"

# Node 24+ only honors HTTP(S)_PROXY/ALL_PROXY for fetch when the
# --use-env-proxy runtime flag is enabled. Add it through NODE_OPTIONS so the
# main CLI and every Node child/provider inherit the same transport policy.
# Older supported Node versions ignore this block because the flag probe fails.
if [ -n "${HTTP_PROXY:-}${HTTPS_PROXY:-}${ALL_PROXY:-}${http_proxy:-}${https_proxy:-}${all_proxy:-}" ]; then
  case " ${NODE_OPTIONS:-} " in
    *" --use-env-proxy "*) ;;
    *)
      if node -p 'process.allowedNodeEnvironmentFlags?.has("--use-env-proxy") ? "yes" : "no"' 2>/dev/null | grep -qx yes; then
        export NODE_OPTIONS="${NODE_OPTIONS:+$NODE_OPTIONS }--use-env-proxy"
      fi
      ;;
  esac
fi

# Compatibility for upstream pi extensions. Keep legacy PI_* paths pointed at
# REPI's isolated profile so packages such as @narumitw/pi-goal and
# pi-web-access do not fall back to ~/.pi when loaded by repi.
export PI_CODING_AGENT_DIR="${PI_CODING_AGENT_DIR:-$REPI_CODING_AGENT_DIR}"
export PI_CODING_AGENT_SESSION_DIR="${PI_CODING_AGENT_SESSION_DIR:-$REPI_CODING_AGENT_SESSION_DIR}"
if [ -n "${REPI_ALLOW_BROWSER_COOKIES:-}" ] && [ -z "${PI_ALLOW_BROWSER_COOKIES:-}" ]; then
  export PI_ALLOW_BROWSER_COOKIES="$REPI_ALLOW_BROWSER_COOKIES"
fi
export REPI_REPO_ROOT="$ROOT"

REPI_DIST_CLI="$ROOT/packages/coding-agent/dist/cli.js"
REPI_DIST_MANIFEST="$ROOT/packages/coding-agent/dist/repi-runtime.json"
REPI_RUNTIME_MARKER="$ROOT/scripts/reverse-agent/mark-repi-runtime.mjs"
REPI_SOURCE_CLI="$ROOT/packages/coding-agent/src/cli.ts"

repi_dist_candidate_is_current() {
  [ "${REPI_USE_SOURCE:-0}" != "1" ] || return 1
  [ -f "$REPI_DIST_MANIFEST" ] || return 1

  local package entry config newer
  for config in "$ROOT/package-lock.json" "$ROOT/tsconfig.base.json"; do
    if [ -f "$config" ] && [ "$config" -nt "$REPI_DIST_MANIFEST" ]; then
      return 1
    fi
  done

  for package in tui ai agent coding-agent; do
    case "$package" in
      tui) entry="$ROOT/packages/tui/dist/index.js" ;;
      ai) entry="$ROOT/packages/ai/dist/index.js" ;;
      agent) entry="$ROOT/packages/agent/dist/index.js" ;;
      coding-agent) entry="$REPI_DIST_CLI" ;;
    esac
    [ -f "$entry" ] || return 1
    [ ! "$entry" -nt "$REPI_DIST_MANIFEST" ] || return 1

    for config in "$ROOT/packages/$package/package.json" "$ROOT/packages/$package/tsconfig.build.json"; do
      if [ -f "$config" ] && [ "$config" -nt "$REPI_DIST_MANIFEST" ]; then
        return 1
      fi
    done
  done

  newer="$(find \
    "$ROOT/packages/tui/src" \
    "$ROOT/packages/ai/src" \
    "$ROOT/packages/agent/src" \
    "$ROOT/packages/coding-agent/src" \
    -newer "$REPI_DIST_MANIFEST" -print -quit 2>/dev/null || true)"
  [ -z "$newer" ] || return 1

  [ -f "$ROOT/packages/coding-agent/dist/modes/interactive/theme/dark.json" ] || return 1
  [ -f "$ROOT/packages/coding-agent/dist/modes/interactive/theme/light.json" ] || return 1
  [ ! "$ROOT/packages/coding-agent/dist/modes/interactive/theme/dark.json" -nt "$REPI_DIST_MANIFEST" ] || return 1
  [ ! "$ROOT/packages/coding-agent/dist/modes/interactive/theme/light.json" -nt "$REPI_DIST_MANIFEST" ] || return 1

  [ -f "$REPI_RUNTIME_MARKER" ] || return 1
}

run_repi_cli() {
  if repi_dist_candidate_is_current; then
    exec node "$REPI_RUNTIME_MARKER" "$ROOT" --launch -- "$@"
  fi
  if [ -x "$ROOT/node_modules/.bin/tsx" ] && [ -f "$REPI_SOURCE_CLI" ]; then
    exec "$ROOT/node_modules/.bin/tsx" --tsconfig "$ROOT/tsconfig.json" "$REPI_SOURCE_CLI" "$@"
  fi

  echo "REPI runtime is unavailable: no current production build or source runner was found." >&2
  echo "Run 'npm install --ignore-scripts && npm run build' in $ROOT." >&2
  exit 1
}

validate_repi_env_model_config() {
  local has_model_config=0
  if [ -n "${REPI_BASE_URL:-}${REPI_MODEL_BASE_URL:-}${REPI_API_BASE_URL:-}${REPI_ENDPOINT:-}${REPI_MODEL_ENDPOINT:-}${REPI_MODEL:-}${REPI_MODEL_ID:-}${REPI_MODEL_API:-}${REPI_API:-}" ]; then
    has_model_config=1
  fi
  [ "$has_model_config" -eq 1 ] || return 0

  local model="${REPI_MODEL:-${REPI_MODEL_ID:-}}"
  local base_url="${REPI_BASE_URL:-${REPI_MODEL_BASE_URL:-${REPI_API_BASE_URL:-${REPI_ENDPOINT:-${REPI_MODEL_ENDPOINT:-}}}}}"
  if [ -n "$model" ] && [ -n "$base_url" ]; then
    local model_api="${REPI_MODEL_API:-${REPI_API:-}}"
    if [ -n "$model_api" ]; then
      model_api="${model_api,,}"
      model_api="${model_api//_/-}"
      case "$model_api" in
        openai-compatible|openai-chat|chat|chat-completions|openai-completions|response|responses|openai-response|openai-responses|anthropic|claude|anthropic-compatible|anthropic-messages) ;;
        *)
          echo "REPI env model config is incomplete or invalid; refusing to fall back to a saved/default model." >&2
          printf '  invalid: REPI_MODEL_API="%s"\n' "${REPI_MODEL_API:-${REPI_API:-}}" >&2
          echo "  allowed: openai-compatible | openai-responses | anthropic" >&2
          exit 2
          ;;
      esac
    fi
    return 0
  fi

  echo "REPI env model config is incomplete; refusing to fall back to a saved/default model." >&2
  if [ -z "$model" ]; then
    echo "  missing: REPI_MODEL" >&2
  fi
  if [ -z "$base_url" ]; then
    echo "  missing: REPI_BASE_URL" >&2
  fi
  cat >&2 <<'MSG'

Use a complete, quoted block, for example:
  export REPI_AUTH_TOKEN="sk-xxxxx"
  export REPI_BASE_URL="https://api.example.com/v1"
  export REPI_PROVIDER="gateway"      # optional display/provider id
  export REPI_MODEL="vendor/model-id"
  export REPI_MODEL_API="openai-compatible"

If your prompt is currently just `>`, press Ctrl+C first: bash is waiting for an unmatched quote.
MSG
  exit 2
}

is_repi_list_models_metadata_request() {
  local arg list_models_count=0
  for arg in "$@"; do
    case "$arg" in
      --offline|--recon|--reverse-pentest) ;;
      --list-models) list_models_count=$((list_models_count + 1)) ;;
      *) return 1 ;;
    esac
  done
  [ "$list_models_count" -eq 1 ]
}

case "${1:-}" in
  install|setup)
    if [ "${1:-}" = "install" ] && [ "$#" -ge 2 ]; then
      case "${2:-}" in
        --root|--bin-dir|--user|--system|-h|--help) ;;
        *)
          run_repi_cli "$@"
          ;;
      esac
    fi
    shift
    exec bash "$ROOT/scripts/reverse-agent/install-repi.sh" --root "$ROOT" "$@"
    ;;
  update|upgrade)
    if [ "${1:-}" = "update" ] && [ "$#" -ge 2 ]; then
      if [ "${2:-}" = "pi" ]; then
        echo "REPI does not manage upstream pi." >&2
        echo "repi update only updates REPI packages/source checkout; use your normal pi installer for upstream pi." >&2
        exit 2
      fi
      case "${2:-}" in
        --root|--fast|--full|--no-pull|--skip-npm|--bin-dir|--user|--system|-h|--help) ;;
        *)
          run_repi_cli "$@"
          ;;
      esac
    fi
    shift
    exec bash "$ROOT/scripts/reverse-agent/update-repi.sh" --root "$ROOT" "$@"
    ;;
  bootstrap)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-bootstrap.mjs" "$ROOT" "$@"
    ;;
  uninstall)
    # `uninstall <source>` is the package-manager alias for remove. Keep the
    # launcher lifecycle command for the no-source form and its own flags.
    case "${2:-}" in
      -l|--local|-a|--approve|-na|--no-approve)
        run_repi_cli "$@"
        ;;
      --apply|--purge|--yes|-y|-h|--help|--source|--source=*)
        ;;
      --*)
        ;;
      "")
        ;;
      *)
        run_repi_cli "$@"
        ;;
    esac
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-uninstall.mjs" "$ROOT" "$@"
    ;;
  commands)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-commands.mjs" "$ROOT" "$@"
    ;;
  trust)
    shift
    exec node "$ROOT/scripts/reverse-agent/trust-inspect.mjs" "$ROOT" "$@"
    ;;
  health|status)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-health.mjs" "$ROOT" "$@"
    ;;
  doctor)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-doctor.mjs" "$ROOT" "$@"
    ;;
  smoke)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-smoke.mjs" "$ROOT" "$@"
    ;;
  selfcheck|dogfood)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-selfcheck.mjs" "$ROOT" "$@"
    ;;
  bugreport)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-bugreport.mjs" "$ROOT" "$@"
    ;;
  mission)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-mission.mjs" "$ROOT" "$@"
    ;;
  engage|attack|reverse|web)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-engage.mjs" "$ROOT" "$@"
    ;;
  mcp)
    case "${2:-}" in
      -h|--help) ;;
      -*) run_repi_cli "$@" ;;
    esac
    sub="${2:-status}"
    if [ "$#" -ge 2 ]; then shift 2; else shift 1; fi
    case "$sub" in
      status|config|list|tools|probe|search|find|call|resources|read-resource|resource|read|prompts|get-prompt|prompt|auth-info|auth|help|--help|-h)
        exec node "$ROOT/scripts/reverse-agent/repi-mcp.mjs" "$ROOT" "$sub" "$@"
        ;;
      *)
        echo "Unknown repi mcp command: $sub" >&2
        echo "Run: repi mcp --help" >&2
        exit 2
        ;;
    esac
    ;;
  swarm)
    case "${2:-}" in
      -h|--help) ;;
      -*) run_repi_cli "$@" ;;
    esac
    sub="${2:-help}"
    if [ "$#" -ge 2 ]; then shift 2; else shift 1; fi
    case "$sub" in
      plan|run|status|list|resolve|merge|llm-run|run-llm|workers)
        exec node "$ROOT/scripts/reverse-agent/repi-swarm-llm-run.mjs" "$ROOT" "$sub" "$@"
        ;;
      help|--help|-h)
        exec node "$ROOT/scripts/reverse-agent/repi-swarm-llm-run.mjs" "$ROOT" --help
        ;;
      *)
        echo "Unknown repi swarm command: $sub" >&2
        echo "Run: repi swarm --help" >&2
        exit 2
        ;;
    esac
    ;;
  model|models)
    case "${2:-}" in
      -h|--help) ;;
      -*) run_repi_cli "$@" ;;
    esac
    sub="${2:-doctor}"
    if [ "$#" -ge 2 ]; then shift 2; else shift 1; fi
    case "$sub" in
      doctor|status|list|cost|add|edit|remove|login|test|default|export|import|help|--help|-h)
        exec node "$ROOT/scripts/reverse-agent/model-inspect.mjs" "$ROOT" "$sub" "$@"
        ;;
      *)
        echo "Unknown repi model command: $sub" >&2
        echo "Run: repi model --help" >&2
        exit 2
        ;;
    esac
    ;;
esac

validate_repi_env_model_config
if is_repi_list_models_metadata_request "$@"; then
  exec node "$ROOT/scripts/reverse-agent/model-inspect.mjs" "$ROOT" list --cli-format
fi
run_repi_cli "$@"
