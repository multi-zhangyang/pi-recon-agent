#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then SOURCE="$DIR/$TARGET"; else SOURCE="$TARGET"; fi
done
ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"

export PI_CODING_AGENT_APP_NAME="repi"
export PI_CODING_AGENT_CONFIG_DIR=".repi"
export REPI_CODING_AGENT_DIR="${REPI_CODING_AGENT_DIR:-${REPI_AGENT_DIR:-$HOME/.repi/agent}}"
export REPI_CODING_AGENT_SESSION_DIR="${REPI_CODING_AGENT_SESSION_DIR:-$REPI_CODING_AGENT_DIR/sessions}"

ARGS=(--recon --no-extensions --no-skills --no-prompt-templates --no-approve --no-context-files)
USER_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --import-pi-auth|--import-pi-profile)
      # One-way, opt-in bootstrap from ~/.pi/agent/{auth,models}.json into ~/.repi/agent.
      # Default repi startup never reads/copies normal pi credentials or model scopes.
      export REPI_IMPORT_PI_PROFILE=1
      ;;
    --project-context)
      # Opt in to project AGENTS/CLAUDE and project .pi settings/resources.
      ARGS=(--recon --no-extensions --no-skills --no-prompt-templates)
      ;;
    --with-project-resources)
      # Opt in to project/global resource discovery as normal pi would do. Not recommended for clean-room runs.
      ARGS=(--recon)
      ;;
    *) USER_ARGS+=("$arg") ;;
  esac
done

node "$ROOT/scripts/reverse-agent/init-repi-profile.mjs" "$ROOT"

exec "$ROOT/node_modules/.bin/tsx" --tsconfig "$ROOT/tsconfig.json" "$ROOT/packages/coding-agent/src/cli.ts" "${ARGS[@]}" "${USER_ARGS[@]}"
