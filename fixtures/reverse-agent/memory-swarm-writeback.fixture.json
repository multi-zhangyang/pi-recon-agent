{
  "kind": "repi-memory-swarm-writeback-fixture",
  "schemaVersion": 1,
  "description": "Hard-eval fixture for re_swarm run worker result writeback into transactional MemoryStoreV5.",
  "swarm": {
    "mode": "run",
    "target": "https://app.example.test",
    "claimLedgerPath": "/tmp/repi/swarm-claim-ledger.jsonl",
    "structuredClaimMergePath": "/tmp/repi/swarm-structured-claim-merge.json",
    "subagentRuntimeManifestPath": "/tmp/repi/swarm-subagent-runtime-manifests.json",
    "workers": [
      {
        "id": "worker-web-authz",
        "worker": "web-authz",
        "status": "done",
        "mergeKeys": ["route-graph", "authz-replay"],
        "evidenceContract": ["request order", "principal/object comparison", "artifact sha256"],
        "sourceArtifacts": ["/tmp/repi/delegation.md"]
      },
      {
        "id": "worker-pwn",
        "worker": "pwn",
        "status": "blocked",
        "mergeKeys": ["crash", "offset"],
        "evidenceContract": ["mitigations", "crash artifact", "controllable bytes"],
        "sourceArtifacts": ["/tmp/repi/pwn-plan.md"]
      }
    ],
    "executions": [
      {
        "workerId": "worker-web-authz",
        "worker": "web-authz",
        "status": "done",
        "command": "node tools/authz-replay.mjs https://app.example.test",
        "output": "stable owner/non-owner diff sha256=aaaaaaaaaaaaaaaa"
      },
      {
        "workerId": "worker-pwn",
        "worker": "pwn",
        "status": "blocked",
        "command": "python3 exploit.py",
        "output": "missing libc; needs leak"
      }
    ],
    "subagentRuntimeManifests": [
      {
        "kind": "SubagentRuntimeManifestV1",
        "workerId": "worker-web-authz",
        "roleId": "web-authz",
        "status": "done",
        "runtimeManifestFile": "/tmp/repi/sessions/worker-web-authz/runtime-manifest.json",
        "stdoutPath": "/tmp/repi/sessions/worker-web-authz/stdout.txt",
        "stderrPath": "/tmp/repi/sessions/worker-web-authz/stderr.txt",
        "stdoutSha256": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "stderrSha256": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
        "toolCallDigest": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      },
      {
        "kind": "SubagentRuntimeManifestV1",
        "workerId": "worker-pwn",
        "roleId": "pwn",
        "status": "blocked",
        "runtimeManifestFile": "/tmp/repi/sessions/worker-pwn/runtime-manifest.json",
        "stdoutPath": "/tmp/repi/sessions/worker-pwn/stdout.txt",
        "stderrPath": "/tmp/repi/sessions/worker-pwn/stderr.txt",
        "stdoutSha256": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
        "stderrSha256": "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee",
        "toolCallDigest": "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
      }
    ]
  },
  "expectations": {
    "mustWriteEvents": 2,
    "mustHaveDomainTags": ["swarm-worker", "memory-swarm-writeback", "MemoryStoreV5"],
    "mustIncludeArtifacts": ["claimLedgerPath", "structuredClaimMergePath", "subagentRuntimeManifestPath", "runtimeManifestFile", "stdoutPath", "stderrPath"],
    "mustCaptureOutcomes": ["success", "blocked"],
    "mustSkipModes": ["plan", "merge"],
    "mustUseTransactionalAppend": true,
    "mustExposeFormatterBlock": "memory_swarm_writeback:",
    "mustHaveRuntimeMarkers": [
      "function appendSwarmWorkerMemoryEvents",
      "appendSwarmWorkerMemoryEvents(swarm)",
      "memory-swarm-writeback",
      "SubagentRuntimeManifestV1",
      "MemoryStoreV5",
      "memory_swarm_writeback:"
    ]
  }
}
