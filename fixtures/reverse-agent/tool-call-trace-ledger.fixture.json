{
  "kind": "repi-tool-call-trace-ledger-fixture",
  "schemaVersion": 1,
  "description": "ToolCallTraceLedgerV1 fixture for append_only_tool_trace, secret_redaction_required, replayable_tool_result_hashes, result_requires_prior_call.",
  "negativeCases": [
    {
      "id": "negative:tool-trace-hash-drift",
      "mutate": "hashDrift",
      "expectedErrors": ["eventHash"]
    },
    {
      "id": "negative:tool-trace-secret-leak",
      "mutate": "secretLeak",
      "expectedErrors": ["literalSecret"]
    },
    {
      "id": "negative:tool-trace-result-without-call",
      "mutate": "missingCall",
      "expectedErrors": ["prevHash", "resultWithoutCall"]
    },
    {
      "id": "negative:tool-trace-missing-output-hash",
      "mutate": "missingOutputHash",
      "expectedErrors": ["outputSha256"]
    },
    {
      "id": "negative:tool-trace-missing-replay",
      "mutate": "missingReplay",
      "expectedErrors": ["bashReplayMissing"]
    }
  ]
}
