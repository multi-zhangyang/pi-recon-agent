  "negativeCases": [
    {
      "id": "worker-id-mismatch",
      "mutates": [
        "providerWorker.workerId=other"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "swarm_subagent_manifest_fields_match_provider_worker"
      ]
    },
    {
      "id": "claim-ref-dropped",
      "mutates": [
        "providerWorker.claimRefs=[]"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "claim_refs_preserved_across_manifest_provider_merge"
      ]
    },
    {
      "id": "missing-runtime-hash",
      "mutates": [
        "providerWorker.stdoutSha256=''"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "runtime_artifacts_have_hashes"
      ]
    },
    {
      "id": "literal-provider-secret",
      "mutates": [
        "childSession.sessions[0].provider.apiKeyRef=sk-live-secret"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "provider_env_refs_only"
      ]
    },
    {
      "id": "failure-repair-unlinked",
      "mutates": [
        "parityRows[1].parityChecks.failureRepairLinked=false"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "failure_repair_refs_preserved_across_provider_worker"
      ]
    },
    {
      "id": "single-provider-matrix",
      "mutates": [
        "parityRows[*].providerName=parallel-openai-compatible",
        "sharedMergeLedger.providerNames=[parallel-openai-compatible]"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "multi_provider_workers_share_claim_failure_merge_ledger"
      ]
    },
    {
      "id": "shared-ledger-worker-missing",
      "mutates": [
        "sharedMergeLedger.workerIds drops worker-beta-anthropic-pass"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "multi_provider_workers_share_claim_failure_merge_ledger"
      ]
    },
    {
      "id": "retry-repair-manifest-unbound",
      "mutates": [
        "retryRepairBindings[0].retrySignature=re_swarm:other"
      ],
      "expect": "fail",
      "mustNotPromote": [
        "provider_worker_retry_repair_rows_bound_to_worker_manifest"
      ]
    }
