#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then SOURCE="$DIR/$TARGET"; else SOURCE="$TARGET"; fi
done
ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Pi-RECON primary launcher. This intentionally makes the command name `pi`
# start the reverse/pentest agent while storing all runtime state in ~/.repi/agent.
export PI_CODING_AGENT_APP_NAME="pi"
export PI_CODING_AGENT_CONFIG_DIR=".repi"
export PI_CODING_AGENT_DIR="${PI_RECON_AGENT_DIR:-${PI_CODING_AGENT_DIR:-${REPI_CODING_AGENT_DIR:-${REPI_AGENT_DIR:-$HOME/.repi/agent}}}}"
export PI_CODING_AGENT_SESSION_DIR="${PI_RECON_SESSION_DIR:-${PI_CODING_AGENT_SESSION_DIR:-$PI_CODING_AGENT_DIR/sessions}}"
export REPI_CODING_AGENT_DIR="$PI_CODING_AGENT_DIR"
export REPI_CODING_AGENT_SESSION_DIR="$PI_CODING_AGENT_SESSION_DIR"
export PI_RECON_PRIMARY=1

ARGS=(--recon --no-extensions --no-skills --no-prompt-templates --no-approve --no-context-files)
USER_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --import-pi-auth|--import-pi-profile)
      # One-way, opt-in bootstrap from the backed-up/upstream pi profile into Pi-RECON storage.
      export REPI_IMPORT_PI_PROFILE=1
      ;;
    --project-context)
      ARGS=(--recon --no-extensions --no-skills --no-prompt-templates)
      ;;
    --with-project-resources)
      ARGS=(--recon)
      ;;
    *) USER_ARGS+=("$arg") ;;
  esac
done

node "$ROOT/scripts/reverse-agent/init-repi-profile.mjs" "$ROOT"

exec "$ROOT/node_modules/.bin/tsx" --tsconfig "$ROOT/tsconfig.json" "$ROOT/packages/coding-agent/src/cli.ts" "${ARGS[@]}" "${USER_ARGS[@]}"
